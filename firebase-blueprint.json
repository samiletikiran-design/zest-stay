{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number with country code" },
        "organizationId": { "type": "string", "description": "ID of the organization the user belongs to" },
        "currentHostelId": { "type": "string", "description": "ID of the hostel currently selected by the user" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user was created" }
      },
      "required": ["name", "email", "phone", "organizationId", "role", "createdAt"]
    },
    "Organization": {
      "title": "Organization",
      "description": "Organization details and subscription status",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the organization" },
        "subscriptionType": { "type": "string", "enum": ["Free", "Basic", "Growth", "Unlimited"], "description": "Current subscription plan" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "expired", "trial"], "description": "Status of the subscription" },
        "subscriptionEndDate": { "type": "string", "format": "date-time", "description": "End date of the subscription" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the organization was created" }
      },
      "required": ["name", "subscriptionType", "subscriptionStatus", "createdAt"]
    },
    "Hostel": {
      "title": "Hostel",
      "description": "Hostel details",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "name": { "type": "string", "description": "Name of the hostel" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the hostel was created" }
      },
      "required": ["organizationId", "name", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "Room details within a hostel",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "roomNumber": { "type": "string", "description": "Room number or identifier" },
        "totalBeds": { "type": "number", "description": "Total number of beds in the room" },
        "type": { "type": "string", "enum": ["AC", "Non-AC"], "description": "Type of room" }
      },
      "required": ["organizationId", "hostelId", "roomNumber", "totalBeds", "type"]
    },
    "Bed": {
      "title": "Bed",
      "description": "Bed details within a room",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "roomId": { "type": "string", "description": "ID of the parent room" },
        "bedNumber": { "type": "string", "description": "Bed number or identifier" },
        "status": { "type": "string", "enum": ["vacant", "occupied"], "description": "Current status of the bed" }
      },
      "required": ["organizationId", "hostelId", "roomId", "bedNumber", "status"]
    },
    "Member": {
      "title": "Member",
      "description": "Resident member details",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "name": { "type": "string", "description": "Full name of the member" },
        "phone": { "type": "string", "description": "Phone number of the member" },
        "idProof": { "type": "string", "description": "ID proof details" },
        "roomId": { "type": "string", "description": "ID of the assigned room" },
        "bedId": { "type": "string", "description": "ID of the assigned bed" },
        "rentAmount": { "type": "number", "description": "Monthly rent amount" },
        "deposit": { "type": "number", "description": "Security deposit amount" },
        "joiningDate": { "type": "string", "format": "date", "description": "Date the member joined" },
        "billingType": { "type": "string", "enum": ["anniversary", "fixed_first"], "description": "Billing cycle type" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Current status of the member" },
        "lastPaidMonth": { "type": "string", "description": "Last month for which rent was paid (YYYY-MM)" }
      },
      "required": ["organizationId", "hostelId", "name", "phone", "roomId", "bedId", "rentAmount", "deposit", "joiningDate", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Rent payment record",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "memberId": { "type": "string", "description": "ID of the member making the payment" },
        "memberName": { "type": "string", "description": "Name of the member" },
        "amount": { "type": "number", "description": "Payment amount" },
        "month": { "type": "string", "description": "Month for which payment is made (YYYY-MM)" },
        "date": { "type": "string", "format": "date", "description": "Date of payment" },
        "method": { "type": "string", "enum": ["cash", "upi", "bank", "bank_transfer"], "description": "Payment method" },
        "status": { "type": "string", "enum": ["paid", "partial"], "description": "Payment status" },
        "notes": { "type": "string", "description": "Optional notes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the record was created" }
      },
      "required": ["organizationId", "hostelId", "memberId", "memberName", "amount", "month", "date", "method", "status", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Staff member details",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "name": { "type": "string", "description": "Full name of the staff member" },
        "role": { "type": "string", "description": "Role of the staff member" },
        "phone": { "type": "string", "description": "Phone number" },
        "salary": { "type": "number", "description": "Monthly salary amount" },
        "joinDate": { "type": "string", "format": "date", "description": "Date of joining" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Current status" }
      },
      "required": ["organizationId", "hostelId", "name", "role", "phone", "salary", "joinDate", "status"]
    },
    "SalaryPayment": {
      "title": "SalaryPayment",
      "description": "Staff salary payment record",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "staffId": { "type": "string", "description": "ID of the staff member" },
        "amount": { "type": "number", "description": "Payment amount" },
        "month": { "type": "string", "description": "Month for which salary is paid (YYYY-MM)" },
        "date": { "type": "string", "format": "date", "description": "Date of payment" },
        "status": { "type": "string", "enum": ["paid"], "description": "Payment status" }
      },
      "required": ["organizationId", "hostelId", "staffId", "amount", "month", "date", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Hostel expense record",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string", "description": "ID of the parent organization" },
        "hostelId": { "type": "string", "description": "ID of the parent hostel" },
        "title": { "type": "string", "description": "Title of the expense" },
        "amount": { "type": "number", "description": "Expense amount" },
        "category": { "type": "string", "enum": ["utilities", "maintenance", "food", "other"], "description": "Expense category" },
        "date": { "type": "string", "format": "date", "description": "Date of expense" },
        "description": { "type": "string", "description": "Optional description" }
      },
      "required": ["organizationId", "hostelId", "title", "amount", "category", "date"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "organizations/{orgId}": {
      "schema": "Organization",
      "description": "Organization documents"
    },
    "hostels/{hostelId}": {
      "schema": "Hostel",
      "description": "Hostel documents"
    },
    "rooms/{roomId}": {
      "schema": "Room",
      "description": "Room documents"
    },
    "beds/{bedId}": {
      "schema": "Bed",
      "description": "Bed documents"
    },
    "members/{memberId}": {
      "schema": "Member",
      "description": "Member documents"
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment documents"
    },
    "staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff documents"
    },
    "staffSalaries/{salaryId}": {
      "schema": "SalaryPayment",
      "description": "Staff salary payment documents"
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense documents"
    }
  }
}
